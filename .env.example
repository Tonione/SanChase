# Copy to .env and fill in one or more channels (all optional).
# .env is gitignored.

# --- Slack (easy: Incoming Webhook in your workspace) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- ntfy.sh (free push on phone — install app "ntfy", subscribe to topic) ---
# NTFY_TOPIC=sanchase-your-secret-topic-name

# --- Telegram (free — @BotFather + chat id) ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789

# --- WhatsApp (opens chat pre-filled; you tap Send) ---
# International number, no +, e.g. France 33612345678
# WHATSAPP_PHONE=33612345678

# Always copy link to Mac clipboard + banner notification (default: 1)
# SANCHASE_NOTIFY_CLIPBOARD=1
